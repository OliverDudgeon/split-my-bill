{
  "name": "split-my-bill",
  "license": "MIT",
  "version": "0.2.14",
  "private": true,
  "scripts": {
    "build": "vite build",
    "dev": "vite --open",
    "prepare": "husky",
    "preview": "vite preview",
    "preview:test": "start-server-and-test 'pnpm serve' http://localhost:5000/split-my-bill/",
    "preinstall": "npx -y only-allow pnpm",
    "format": "prettier --write --ignore-unknown --cache --ignore-path .gitignore --ignore-path .prettierignore .",
    "run-tsc": "tsc",
    "run-eslint": "eslint --cache --fix .",
    "run-stylelint": "stylelint --cache --fix \"src/**/*.css\"",
    "lint": "run-p run-tsc run-eslint run-stylelint",
    "validate": "run-s lint build"
  },
  "engines": {
    "node": ">=24",
    "pnpm": ">=11"
  },
  "packageManager": "pnpm@11.2.2",
  "dependencies": {
    "@tesseract.js-data/eng": "1.0.0",
    "byte-base64": "1.1.0",
    "formik": "2.4.9",
    "just-throttle": "4.2.0",
    "pako": "3.0.0",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "tesseract.js": "7.0.0"
  },
  "devDependencies": {
    "@eslint/js": "9.39.4",
    "@nabla/vite-plugin-eslint": "3.0.1",
    "@tailwindcss/vite": "4.3.2",
    "@types/node": "26.1.0",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "eslint": "9.39.4",
    "eslint-config-prettier": "10.1.8",
    "eslint-plugin-import": "2.32.0",
    "eslint-plugin-jsx-a11y": "6.10.2",
    "eslint-plugin-react": "7.37.5",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-prefer-function-component": "5.0.0",
    "eslint-plugin-simple-import-sort": "13.0.0",
    "eslint-plugin-unicorn": "71.1.0",
    "globals": "17.7.0",
    "husky": "9.1.7",
    "lint-staged": "17.0.8",
    "npm-run-all": "4.1.5",
    "prettier": "3.9.4",
    "prettier-plugin-tailwindcss": "0.8.0",
    "start-server-and-test": "3.0.11",
    "stylelint": "17.14.0",
    "stylelint-config-standard": "40.0.0",
    "tailwindcss": "4.3.2",
    "typescript": "6.0.3",
    "typescript-eslint": "8.62.1",
    "vite": "8.1.3",
    "vite-plugin-pwa": "1.3.0",
    "workbox-build": "7.4.1",
    "workbox-window": "7.4.1"
  },
  "lint-staged": {
    "*.css": "stylelint --cache --fix",
    "*.{ts,tsx}": "eslint --cache --fix"
  },
  "browserslist": {
    "production": "Edge >= 18, Firefox >= 60, Chrome >= 61, Safari >= 11, Opera >= 48",
    "development": [
      "last 1 chrome version",
      "last 1 firefox version"
    ]
  }
}
